# ═══════════════════════════════════════════════════
# Emare SuperApp — Ortam Değişkenleri
# Bu dosyayı kopyalayın: cp .env.example .env
# Production'da tüm "change-me" değerlerini değiştirin!
# ═══════════════════════════════════════════════════

# ── Genel ──
APP_NAME=EmareSuperApp
APP_ENV=development          # production | development
DEBUG=false
SECRET_KEY=change-me-in-production-superapp-2026-GUCLU-SIFRE
API_PREFIX=/api/v1
WORKERS=4

# ── Sunucu ──
HOST=0.0.0.0
PORT=8080

# ── Veritabanı ──
DATABASE_URL=sqlite+aiosqlite:///./data/superapp.db
# Production: DATABASE_URL=postgresql+asyncpg://emare:SIFRE@db:5432/emaresuperapp

# ── PostgreSQL (docker-compose) ──
POSTGRES_DB=emaresuperapp
POSTGRES_USER=emare
POSTGRES_PASSWORD=GUCLU_SIFRE_BURAYA

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT ──
JWT_SECRET=change-me-jwt-secret-GUCLU-VE-UZUN-SIFRE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Email ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── AI API Anahtarları ──
GEMINI_API_KEY=
OPENAI_API_KEY=

