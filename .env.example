# ═══════════════════════════════════════════════════
# Emare SuperApp — Ortam Değişkenleri
# Bu dosyayı kopyalayın: cp .env.example .env
# Production'da tüm "change-me" değerlerini değiştirin!
# ═══════════════════════════════════════════════════

# ── Genel ──
APP_NAME=EmareSuperApp
APP_ENV=development          # production | development
DEBUG=false                   # Production'da mutlaka false!
SECRET_KEY=change-me-in-production-superapp-2026-GUCLU-SIFRE
API_PREFIX=/api/v1
WORKERS=4                     # Production'da CPU sayısı * 2

# ── Sunucu ──
HOST=0.0.0.0
PORT=8080

# ── Veritabanı ──
# Geliştirme:
DATABASE_URL=sqlite+aiosqlite:///./data/superapp.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://emare:GUCLU_SIFRE@db:5432/emaresuperapp

# ── PostgreSQL (docker-compose için) ──
POSTGRES_DB=emaresuperapp
POSTGRES_USER=emare
POSTGRES_PASSWORD=GUCLU_SIFRE_BURAYA   # Production'da mutlaka değiştir!

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
# Production: REDIS_URL=redis://redis:6379/0

# ── JWT ──
JWT_SECRET=change-me-jwt-secret-GUCLU-VE-UZUN-SIFRE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60         # Token süresi (saat * 60)

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# Production: CORS_ORIGINS=https://app.emare.com,https://emare.com

# ── Email ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── AI ──
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Emare Ekosistem ──
EMARE_HUB_URL=http://localhost:5555
EMARE_CLOUD_URL=http://77.92.152.3:5000
EMARE_ASISTAN_URL=http://77.92.152.3:8000
